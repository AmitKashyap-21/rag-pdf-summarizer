# Application
APP_NAME=RAG PDF Summarizer
DEBUG=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# OpenRouter (Single API Key for both LLM and Embeddings)
OPENROUTER_API_KEY=sk_or_xxxxx_REQUIRED
OPENROUTER_LLM_MODEL=openai/gpt-3.5-turbo
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=30
OPENROUTER_MAX_RETRIES=3

# Database
DATABASE_URL=postgresql://raguser:ragpassword@localhost:5432/rag_pdf

# File Storage
STORAGE_PATH=./uploads
INDEXES_PATH=./indexes
MAX_FILE_SIZE_MB=50

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# FAISS
FAISS_METRIC=L2

# API Security
API_KEY=changeme-replace-in-production
